#!/usr/bin/env bash
# Management CLI for nut-up.
# First install: sudo ./nutup install
# After install: nutup <command> from anywhere
set -e
REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

cmd="${1:-help}"

if [[ ! -f "$REPO/Makefile" ]]; then
    echo "nutup: repository not found at $REPO" >&2
    echo "Re-clone the repository and run: sudo ./nutup install" >&2
    exit 1
fi

show_help() {
    echo "Usage: nutup <command> [args]"
    echo ""
    echo "System commands (require sudo):"
    echo "  install      Install nut-up (venv, systemd service, config template)"
    echo "  update       Pull latest changes, reinstall package, and restart the service"
    echo "  test         Check NUT server connectivity, credentials, and IPMI BMC access"
    echo "  lock         Regenerate requirements.lock from the installed venv"
    echo "  uninstall    Stop and disable service, remove venv and unit file (config kept)"
    echo "  purge        Remove everything: config, system user, and this repo"
    echo ""
    echo "Runtime commands:"
    echo "  daemon       Start the poll loop and API/web server"
    echo "  discover     Discover NUT slave clients and print ready-to-paste config YAML"
    echo "  wake NAME    Wake a machine by name (or 'all')"
    echo "  status       Show current UPS and machine status from the running daemon"
}

case "$cmd" in
    update)
        if [[ $EUID -ne 0 ]]; then
            exec sudo "$0" "$cmd"
        fi
        git -C "$REPO" pull
        exec make -C "$REPO" update
        ;;
    install|test|lock|uninstall|purge)
        if [[ $EUID -ne 0 ]]; then
            exec sudo "$0" "$cmd"
        fi
        exec make -C "$REPO" "$cmd"
        ;;
    help)
        show_help
        ;;
    daemon|discover|wake|status)
        if [[ "$(id -un)" != "nut-up" ]]; then
            exec sudo -u nut-up /opt/nut-up/bin/nut-up "$@"
        fi
        exec /opt/nut-up/bin/nut-up "$@"
        ;;
    *)
        echo "nutup: unknown command '${cmd}'" >&2
        echo "" >&2
        show_help >&2
        exit 1
        ;;
esac
